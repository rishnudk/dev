generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}



// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────
model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  username    String?  @unique
  avatarUrl   String?
  bio         String?
  field       Field?
  portfolioUrl String?
  githubUrl   String?
  linkedinUrl String?
  techStack   String[]
  isOnboarded Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  portfolios  Portfolio[]
  votes       Vote[]
  magicTokens MagicToken[]

  @@map("users")
}

// ─────────────────────────────────────────
// FIELD ENUM
// ─────────────────────────────────────────
enum Field {
  FRONTEND
  BACKEND
  FULLSTACK
  MOBILE
  DEVOPS
  DATA
  DESIGN
  OTHER
}

// ─────────────────────────────────────────
// PORTFOLIO
// ─────────────────────────────────────────
model Portfolio {
  id             String   @id @default(cuid())
  userId         String
  title          String
  description    String
  liveUrl        String
  heroImageUrl   String
  trendingScore  Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes          Vote[]
  tags           PortfolioTag[]

  // Indexes — important for feed queries
  @@index([trendingScore(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([userId])
  @@map("portfolios")
}

// ─────────────────────────────────────────
// VOTE
// ─────────────────────────────────────────
model Vote {
  id          String   @id @default(cuid())
  userId      String
  portfolioId String
  createdAt   DateTime @default(now())

  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  // One vote per user per portfolio — enforced at DB level
  @@unique([userId, portfolioId])
  @@index([portfolioId])
  @@map("votes")
}

// ─────────────────────────────────────────
// TAG
// ─────────────────────────────────────────
model Tag {
  id         String         @id @default(cuid())
  name       String         @unique
  portfolios PortfolioTag[]

  @@map("tags")
}

// ─────────────────────────────────────────
// PORTFOLIO TAG (Join Table)
// ─────────────────────────────────────────
model PortfolioTag {
  portfolioId String
  tagId       String

  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([portfolioId, tagId])
  @@map("portfolio_tags")
}

// ─────────────────────────────────────────
// MAGIC TOKEN (for passwordless auth)
// ─────────────────────────────────────────
model MagicToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("magic_tokens")
}